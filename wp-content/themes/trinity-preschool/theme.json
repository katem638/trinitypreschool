{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	],
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"slug": "ink",
					"color": "#2f6fa3",
					"name": "Trinity Blue"
				},
				{
					"slug": "paper",
					"color": "#fbf7ec",
					"name": "Warm Cream"
				},
				{
					"slug": "sky",
					"color": "#9fc0d1",
					"name": "Soft Sky"
				},
				{
					"slug": "leaf",
					"color": "#6f99b6",
					"name": "Dusty Blue"
				},
				{
					"slug": "sun",
					"color": "#f4c95d",
					"name": "Sun"
				},
				{
					"slug": "coral",
					"color": "#ef8a73",
					"name": "Coral"
				}
			]
		},
		"layout": {
			"contentSize": "760px",
			"wideSize": "1180px"
		},
		"spacing": {
			"spacingScale": {
				"steps": 0
			},
			"spacingSizes": [
				{
					"slug": "20",
					"size": "0.75rem",
					"name": "2"
				},
				{
					"slug": "30",
					"size": "1.25rem",
					"name": "3"
				},
				{
					"slug": "40",
					"size": "2rem",
					"name": "4"
				},
				{
					"slug": "50",
					"size": "3rem",
					"name": "5"
				},
				{
					"slug": "60",
					"size": "4.5rem",
					"name": "6"
				}
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "rounded",
					"fontFamily": "'Nunito Sans', 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
					"name": "Nunito Sans"
				},
				{
					"slug": "display",
					"fontFamily": "'Fraunces', Georgia, 'Times New Roman', serif",
					"name": "Fraunces"
				},
				{
					"slug": "serif",
					"fontFamily": "Georgia, 'Times New Roman', serif",
					"name": "Serif"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.95rem",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "1.08rem",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "1.8rem",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "clamp(2.4rem, 5vw, 4.8rem)",
					"name": "Extra Large"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|paper",
			"text": "var:preset|color|ink"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|rounded",
			"fontSize": "var:preset|font-size|medium",
			"fontWeight": "500",
			"lineHeight": "1.55"
		},
		"elements": {
			"button": {
				"border": {
					"radius": "8px"
				},
				"color": {
					"background": "var:preset|color|leaf",
					"text": "var:preset|color|paper"
				},
				"spacing": {
					"padding": {
						"top": "0.8rem",
						"right": "1.15rem",
						"bottom": "0.8rem",
						"left": "1.15rem"
					}
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|rounded",
					"fontWeight": "700",
					"lineHeight": "1.08"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|ink"
				}
			}
		}
	}
}
