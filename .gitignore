# Keep local WordPress core and generated/runtime files out of git.
/wp-admin/
/wp-includes/
/index.php
/license.txt
/readme.html
/wp-*.php
/xmlrpc.php
/wp-config.php
/wp-config-sample.php
/wp-config-ddev.php

# Content generated by WordPress at runtime.
wp-content/uploads/
wp-content/upgrade/
wp-content/cache/
wp-content/debug.log
wp-content/index.php
wp-content/plugins/index.php
wp-content/themes/index.php

# Local transfer/backup artifacts. Keep database dumps out of git.
.site-transfer/
*.sql
*.sql.gz
*.sql.xz

# Bundled starter content from core installs.
wp-content/plugins/akismet/
wp-content/plugins/hello.php
wp-content/themes/twentytwentythree/
wp-content/themes/twentytwentyfour/
wp-content/themes/twentytwentyfive/

# OS/editor noise.
.DS_Store
*.swp
